--הגדרת משתנים--
let--מילה שמורה
--case sensitive--
ניתן להכניס לאובייקט כמה ערכים:
let user = 'John', age = 25, message = 'Hello';
או
let user = 'John';
let age = 25;
let message = 'Hello';
--.1 השם חייב להכיל אותיות או/ו מספרים או/ו את הסימנים _ $,
--.2 האות הראשונה חייבת להיות לא ספרה
--undefined--משתנים שהוכרזו אבל לא אותחלו
--var--משתנה שהוגדר ככה קיים גם מחוץ לפונקציה או ללולאה לעומת let
let שהוגדר בתוך לולאה,אם נדפיס אותו מחוץ ללולאה יודפס כלא מוגדר
ניתן להגדיר var יותר מפעם אחת(גם אחרי שהכרזנו)

