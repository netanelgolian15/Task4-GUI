--getElementById--
document.getElementById("someId")
document.getElementById("btn").value="click me";--משנה את הטקסט של הכפתור
document.getElementById("btn").style.color="red";--משנה את הצבע

.value-----רק עבור אלמנטים שהמשתמש יכול להקליד או לבחור ערך
.innerText----מתי להשתמש: בתוך p, h1-h6, span, div, li.
.innerHTML----את כל התוכן כולל תגיות HTML.

